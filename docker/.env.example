# Production sidecar env — copy to docker/.env and edit.
# See README "Docker sidecar" for network setup.

IMMICH_URL=http://immich-server:2283/api
IMMICH_API_KEY=

HASH_DB_PATH=/data/hashes.sqlite3

# Sidecar defaults: thumbnail hashing is faster; originals are used at export time.
WIGGLE_HASH_SOURCE=thumbnail
WIGGLE_THRESHOLD=10
WIGGLE_TIME_WINDOW_SECONDS=3.0
WIGGLE_MAX_GAP_FRAMES=1
WIGGLE_SETTLE_SECONDS=15
WIGGLE_FRAME_DURATION_MS=100
WIGGLE_MAX_SIZE=600
WIGGLE_BOOMERANG=true
WIGGLE_ALBUM_NAME=Wigglegrams
WIGGLE_STACK_WITH_SOURCES=true
INDEX_WORKERS=4
DAEMON_POLL_INTERVAL_SECONDS=60
DEVICE_ID=image-helper
