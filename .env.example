# Immich instance URL (include /api suffix)
IMMICH_URL=http://localhost:2283/api

# API key from Immich: Account Settings -> API Keys
# Required permissions: asset.read, asset.download, asset.upload, album.read, album.write
IMMICH_API_KEY=your-api-key-here

# SQLite database path for perceptual hash cache
HASH_DB_PATH=./data/hashes.sqlite3

# Wiggle detection defaults
WIGGLE_THRESHOLD=10
WIGGLE_TIME_WINDOW_SECONDS=3.0
WIGGLE_FRAME_DURATION_MS=100
WIGGLE_MAX_SIZE=600
WIGGLE_BOOMERANG=true

# Output album name for exported GIFs
WIGGLE_ALBUM_NAME=Wigglegrams

# Daemon polling interval (seconds)
DAEMON_POLL_INTERVAL_SECONDS=60

# Phase 2 webhook receiver (optional)
WEBHOOK_HOST=0.0.0.0
WEBHOOK_PORT=8765
WEBHOOK_SECRET=
