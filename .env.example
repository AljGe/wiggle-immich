# Immich connection (required)
IMMICH_URL=http://localhost:2283/api
IMMICH_API_KEY=

# Local data
HASH_DB_PATH=./data/hashes.sqlite3

# Wiggle detection
WIGGLE_THRESHOLD=10
WIGGLE_MIN_DISTANCE=2
WIGGLE_TIME_WINDOW_SECONDS=3.0
WIGGLE_MAX_GAP_FRAMES=0
WIGGLE_SETTLE_SECONDS=0
WIGGLE_REQUIRE_BURST_METADATA=false
WIGGLE_HASH_SOURCE=original

# GIF export
WIGGLE_FRAME_DURATION_MS=100
WIGGLE_MAX_SIZE=600
WIGGLE_BOOMERANG=true
WIGGLE_FRAME_FIT=letterbox
WIGGLE_ALBUM_NAME=Wigglegrams
WIGGLE_STACK_WITH_SOURCES=false

# Indexing performance
INDEX_WORKERS=4

# Daemon polling
DAEMON_POLL_INTERVAL_SECONDS=60

# Webhook receiver (optional; requires image-helper[webhook])
WEBHOOK_HOST=0.0.0.0
WEBHOOK_PORT=8765
WEBHOOK_SECRET=

# Upload identity
DEVICE_ID=image-helper
